---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { services, business, hours, hoursMinutes } from "../data/site";
import storefront from "../assets/photos/shave-cave-klippistofa-fakafeni-9-reykjavik.jpg";
import teamPhoto from "../assets/photos/shave-cave-teymi-klippistofa-reykjavik.jpg";
import galleryPool from "../assets/photos/shave-cave-billjardbord-reykjavik.jpg";
import gallerySalon from "../assets/photos/shave-cave-klippistofa-innanhuss-reykjavik.jpg";
import galleryLounge from "../assets/photos/shave-cave-afthreyingarrymi-reykjavik.jpg";

// Gallery photos — tile aspect matched to each photo's orientation so
// object-cover crops as little as possible.
const galleryPhotos = [
  { img: galleryPool, alt: "Útskorið Shave Cave merki og billjardborð inni á klippistofunni í Reykjavík", w: "24rem", h: "24rem" },
  { img: gallerySalon, alt: "Klippistofa Shave Cave að innan — rakarastólar og upplýstir speglar við Fákafeni 9", w: "20rem", h: "27rem" },
  { img: galleryLounge, alt: "Afþreyingarrými Shave Cave í Reykjavík með leiktækjum og sófa", w: "20rem", h: "27rem" },
];
---

<Layout>
  <!-- ═══════════════════════════════════════════════════════
       NAV
       ═══════════════════════════════════════════════════════ -->
  <header
    id="nav"
    class="fixed top-0 z-50 w-full transition-all duration-500"
  >
    <div
      class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 md:px-10"
    >
      <a
        href="#hero"
        class="flex items-center"
        aria-label="ShaveCave — efst á síðu"
      >
        <img
          src="/images/logo.png"
          alt=""
          width="854"
          height="854"
          class="h-11 w-11 object-contain md:h-12 md:w-12"
        />
      </a>

      <nav class="hidden items-center gap-10 md:flex" aria-label="Primary">
        {
          [
            { label: "Um okkur", href: "#about" },
            { label: "Þjónusta", href: "#services" },
            { label: "Myndir", href: "#gallery" },
            { label: "Finndu okkur", href: "#find-us" },
          ].map((item) => (
            <a
              href={item.href}
              class="group relative font-body text-sm font-medium tracking-[0.15em] uppercase text-stone transition-colors hover:text-amber-light"
            >
              {item.label}
              <span class="absolute -bottom-1 left-0 h-px w-0 bg-amber transition-all duration-300 group-hover:w-full" />
            </a>
          ))
        }
      </nav>

      <div class="hidden items-center gap-4 md:flex">
        <div
          class="flex items-center gap-2"
          id="status-badge"
          data-open-min={hoursMinutes.open}
          data-close-min={hoursMinutes.close}
        >
          <span class="status-dot h-2 w-2 rounded-full bg-stone-dark"></span>
          <span
            class="font-body text-xs font-medium uppercase tracking-widest text-stone-dark"
            id="status-text">—</span
          >
        </div>
      </div>

      <button
        type="button"
        id="nav-toggle"
        class="flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded border border-border bg-surface/80 backdrop-blur-sm md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Opna valmynd"
      >
        <span class="nav-bar block h-[1.5px] w-5 bg-cream transition-all duration-300"></span>
        <span class="nav-bar block h-[1.5px] w-5 bg-cream transition-all duration-300"></span>
        <span class="nav-bar block h-[1.5px] w-5 bg-cream transition-all duration-300"></span>
      </button>
    </div>

    <div
      id="mobile-menu"
      class="fixed inset-0 z-40 flex translate-x-full flex-col bg-void/98 pt-24 backdrop-blur-xl transition-transform duration-500 md:hidden"
    >
      <nav class="flex flex-col gap-2 px-8 py-6" aria-label="Mobile">
        {
          [
            { label: "Um okkur", href: "#about" },
            { label: "Þjónusta", href: "#services" },
            { label: "Myndir", href: "#gallery" },
            { label: "Finndu okkur", href: "#find-us" },
          ].map((item, i) => (
            <a
              href={item.href}
              class="mobile-link border-b border-border py-5 font-display text-2xl tracking-[0.2em] text-cream transition-all hover:text-amber"
              style={`transition-delay: ${i * 80}ms`}
            >
              {item.label}
            </a>
          ))
        }
        <div class="mt-8 flex items-center gap-3" id="mobile-status">
          <span class="status-dot h-2.5 w-2.5 rounded-full bg-stone-dark"
          ></span>
          <span
            class="font-body text-sm tracking-widest text-stone-dark"
            id="mobile-status-text">—</span
          >
        </div>
      </nav>
    </div>
  </header>

  <!-- Fixed logo watermark — stays centered on viewport while scrolling -->
  <div
    id="logo-watermark"
    class="logo-watermark pointer-events-none fixed inset-0 z-[1] flex items-center justify-center"
    aria-hidden="true"
  >
    <div class="logo-watermark-inner relative">
      <div class="absolute inset-[-50%] rounded-full bg-[radial-gradient(circle,rgba(200,150,90,0.10)_0%,rgba(200,150,90,0.03)_40%,transparent_65%)]"></div>
      <img
        src="/images/logo.png"
        alt=""
        class="h-[55vh] w-[55vh] max-h-[550px] max-w-[550px] object-contain drop-shadow-[0_0_120px_rgba(200,150,90,0.2)] sm:h-[65vh] sm:w-[65vh]"
        width="854"
        height="854"
      />
    </div>
  </div>

  <main>
    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section
      class="relative flex min-h-screen flex-col items-center justify-center overflow-hidden px-6"
      aria-label="Hero"
      id="hero"
    >
      <div class="pointer-events-none absolute inset-0 bg-void" aria-hidden="true"></div>

      <div
        class="hero-glow pointer-events-none absolute -top-[20%] left-1/2 h-[140%] w-[160%] -translate-x-1/2"
        aria-hidden="true"
      >
      </div>

      <div
        class="pointer-events-none absolute bottom-0 left-0 h-1/3 w-full bg-gradient-to-t from-void to-transparent"
        aria-hidden="true"
      >
      </div>

      <!-- Ember particles -->
      <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
        {
          Array.from({ length: 15 }).map(() => (
            <div
              class="ember"
              style={`--x: ${8 + Math.random() * 84}%; --delay: ${Math.random() * 12}s; --duration: ${8 + Math.random() * 10}s; width: ${1.5 + Math.random() * 2.5}px; height: ${1.5 + Math.random() * 2.5}px;`}
            />
          ))
        }
      </div>

      <div class="hero-content-delayed relative z-10 mx-auto max-w-5xl text-center">
        <p
          class="reveal mb-8 font-body text-xs font-medium uppercase tracking-[0.6em] text-amber md:text-sm"
        >
          Fákafeni 9 · Reykjavík
        </p>

        <h1
          id="hero-title"
          class="font-display text-[clamp(2rem,10vw,3.2rem)] font-semibold leading-none tracking-[0.18em] text-cream sm:text-7xl md:text-8xl lg:text-9xl"
          aria-label="ShaveCave"
        >
          SHAVE<span class="text-amber">CAVE</span>
        </h1>

        <div
          class="reveal delay-2 mx-auto mt-9 flex items-center justify-center gap-2.5 font-body text-base tracking-[0.12em] text-stone md:text-lg"
        >
          <svg
            class="h-4 w-4 text-amber/80"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span>Mán–Fös</span>
          <span class="tabular-nums text-cream"
            >{hours.weekdayOpen}–{hours.weekdayClose}</span
          >
        </div>

        <div class="mx-auto mt-10 max-w-md">
          <p
            class="reveal delay-3 font-body text-xl leading-relaxed font-normal text-stone md:text-2xl"
          >
            Engar tímapantanir. Ekkert vesen.<br />Bara nákvæmni og handverk.
          </p>
        </div>

        <div
          class="reveal delay-4 mt-14 flex flex-col items-center justify-center gap-4 sm:flex-row"
        >
          <a
            href="https://www.google.com/maps/dir/?api=1&destination=Fákafeni+9,+108+Reykjavík,+Iceland"
            target="_blank"
            rel="noopener noreferrer"
            data-directions
            class="group relative inline-flex items-center justify-center gap-3 overflow-hidden rounded-sm border border-amber/40 bg-amber/10 px-12 py-4 font-body text-base font-medium tracking-[0.2em] uppercase text-amber-light transition-all duration-300 hover:border-amber hover:bg-amber/20 hover:shadow-[0_0_60px_-10px_rgba(200,150,90,0.5)]"
          >
            <svg class="relative z-10 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span class="relative z-10">Leiðarlýsing</span>
            <div
              class="absolute inset-0 -translate-x-full bg-gradient-to-r from-transparent via-amber/10 to-transparent transition-transform duration-700 group-hover:translate-x-full"
            >
            </div>
          </a>
          <a
            href="#services"
            class="inline-flex items-center justify-center rounded-sm border border-border px-12 py-4 font-body text-base font-medium tracking-[0.2em] uppercase text-stone transition-all duration-300 hover:border-amber/40 hover:text-cream"
          >
            Þjónusta
          </a>
        </div>
      </div>

      <a
        href="#about"
        class="hero-content-delayed absolute bottom-12 left-1/2 z-10 -translate-x-1/2 text-stone transition-colors hover:text-amber"
        aria-label="Scroll down"
      >
        <svg
          class="h-7 w-7 animate-chevron-bounce"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M19 9l-7 7-7-7"></path>
        </svg>
      </a>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         ABOUT
         ═══════════════════════════════════════════════════════ -->
    <section id="about" class="relative scroll-mt-24 bg-deep py-28 md:py-36">
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-void via-transparent to-transparent opacity-60" aria-hidden="true"></div>

      <div class="relative z-10 mx-auto grid max-w-7xl gap-16 px-6 md:grid-cols-5 md:gap-20 md:px-10">
        <div class="reveal flex flex-col justify-center md:col-span-3">
          <div class="mb-6 flex items-center gap-4">
            <span class="h-px w-12 bg-amber"></span>
            <span class="font-body text-xs font-medium uppercase tracking-[0.4em] text-amber"
              >Um okkur</span
            >
          </div>

          <h2
            class="font-display text-3xl font-semibold tracking-[0.12em] text-cream md:text-4xl lg:text-5xl"
          >
            Skapað fyrir handverkið
          </h2>

          <p class="mt-8 font-body text-xl leading-relaxed text-stone">
            Shave Cave er klippistofa í Reykjavík sem sérhæfir sig í herraklippingum og skeggsnyrtingum.
            Við blandum saman klassískri tækni og nútíma nákvæmni — engar efnameðhöndlanir, ekkert vesen.
            Bara hvöss verkfæri, stöðugar hendur og rólegt andrúmsloft.
          </p>

          <p class="mt-6 font-body text-xl leading-relaxed text-stone">
            Engar tímapantanir. Klippum alla en sérhæfum okkur í herraklippingum og skeggum —
            skin fade, skeggmótun, rakstur og allt þar á milli.
          </p>

          <div class="mt-12 grid grid-cols-3 gap-6">
            {
              [
                { num: "10+", label: "Ára reynsla" },
                { num: "0", label: "Tímapantanir" },
                { num: "6", label: "Þjónustur" },
              ].map((stat) => (
                <div class="reveal border-l border-border pl-5">
                  <p class="font-display text-2xl font-semibold text-amber md:text-3xl">
                    {stat.num}
                  </p>
                  <p class="mt-1 font-body text-sm tracking-wider text-stone-dark">
                    {stat.label}
                  </p>
                </div>
              ))
            }
          </div>
        </div>

        <div
          class="reveal delay-2 relative md:col-span-2"
        >
          <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-border bg-surface">
            <Image
              src={teamPhoto}
              alt="Teymið hjá Shave Cave klippistofu við Fákafeni 9 í Reykjavík"
              width={1100}
              quality={80}
              format="webp"
              class="absolute inset-0 h-full w-full object-cover"
            />
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-deep/80 via-transparent to-amber/5"
              aria-hidden="true"
            >
            </div>
            <p
              class="absolute bottom-6 left-6 font-display text-[0.6rem] tracking-[0.35em] text-cream/50"
            >
              EST. REYKJAVÍK
            </p>
          </div>

          <div
            class="absolute -top-4 -right-4 h-32 w-32 rounded-full bg-amber/[0.04] blur-3xl"
            aria-hidden="true"
          >
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         SERVICES
         ═══════════════════════════════════════════════════════ -->
    <section id="services" class="relative scroll-mt-24 bg-void py-28 md:py-36">
      <div
        class="pointer-events-none absolute top-0 left-1/2 h-px w-4/5 max-w-4xl -translate-x-1/2 bg-gradient-to-r from-transparent via-amber/30 to-transparent"
        aria-hidden="true"
      >
      </div>

      <div class="mx-auto max-w-7xl px-6 md:px-10">
        <div class="reveal mb-20 max-w-2xl">
          <div class="mb-6 flex items-center gap-4">
            <span class="h-px w-12 bg-amber"></span>
            <span class="font-body text-xs font-medium uppercase tracking-[0.4em] text-amber"
              >Þjónusta</span
            >
          </div>
          <h2
            class="font-display text-3xl font-semibold tracking-[0.12em] text-cream md:text-4xl lg:text-5xl"
          >
            Þjónustan okkar
          </h2>
        </div>

        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3" id="services-grid">
          {
            services.map((s, i) => (
              <article
                class={`service-card reveal ${i > 0 ? `delay-${Math.min(i, 5)}` : ""} group rounded-sm border border-border bg-surface/60 p-8 transition-all duration-500 hover:-translate-y-1 hover:border-amber/30 hover:bg-surface/90 hover:shadow-[0_8px_60px_-15px_rgba(200,150,90,0.2)]`}
              >
                <div class="relative z-10">
                  <h3 class="font-display text-2xl tracking-wide text-cream transition-colors group-hover:text-amber-light">
                    {s.name}
                  </h3>
                  <p class="mt-5 font-body text-base leading-relaxed text-stone">
                    {s.desc}
                  </p>
                </div>
              </article>
            ))
          }
        </div>

        <p class="reveal mt-10 text-center font-body text-base text-stone-dark">
          Engar efnameðhöndlanir
        </p>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         GALLERY
         ═══════════════════════════════════════════════════════ -->
    <section id="gallery" class="relative scroll-mt-24 bg-deep py-28 md:py-36">
      <div
        class="pointer-events-none absolute top-0 left-1/2 h-px w-4/5 max-w-4xl -translate-x-1/2 bg-gradient-to-r from-transparent via-border-light to-transparent"
        aria-hidden="true"
      >
      </div>

      <div class="mx-auto max-w-7xl px-6 md:px-10">
        <div class="reveal mb-16 text-center">
          <div class="mb-6 flex items-center justify-center gap-4">
            <span class="h-px w-12 bg-amber"></span>
            <span class="font-body text-xs font-medium uppercase tracking-[0.4em] text-amber"
              >Rýmið</span
            >
            <span class="h-px w-12 bg-amber"></span>
          </div>
          <h2
            class="font-display text-3xl font-semibold tracking-[0.12em] text-cream md:text-4xl lg:text-5xl"
          >
            Inni í hellinum
          </h2>
          <p class="mt-4 font-body text-lg text-stone">
            Andrúmsloftið í myndum.
          </p>
        </div>
      </div>

      <div
        class="gallery-scroll flex gap-4 overflow-x-auto px-6 pb-4 snap-x snap-mandatory md:px-10"
      >
        <div class="shrink-0 w-[calc(50vw-12rem)] md:w-[calc(50vw-20rem)]" aria-hidden="true"></div>
        {
          galleryPhotos.map((photo, i) => (
            <div
              class={`reveal-scale ${i > 0 ? `delay-${Math.min(i, 5)}` : ""} group relative shrink-0 snap-center overflow-hidden rounded-sm border border-border bg-surface`}
              style={`width: ${photo.w}; height: ${photo.h};`}
            >
              <Image
                src={photo.img}
                alt={photo.alt}
                width={760}
                quality={78}
                format="webp"
                class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
              />
              <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/60 via-transparent to-transparent opacity-70 transition-opacity duration-500 group-hover:opacity-90" />
              <span class="absolute bottom-5 left-5 font-display text-[0.6rem] tracking-[0.3em] text-cream/0 transition-all duration-500 group-hover:text-cream/85">
                SHAVECAVE
              </span>
            </div>
          ))
        }
        <div class="shrink-0 w-[calc(50vw-12rem)] md:w-[calc(50vw-20rem)]" aria-hidden="true"></div>
      </div>

      <div class="mt-8 flex items-center justify-center gap-3">
        <span class="font-body text-xs tracking-widest text-stone-dark">SKROLLA</span>
        <svg class="h-4 w-4 text-stone-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7"
          ></path>
        </svg>
      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         FIND US / CONTACT
         ═══════════════════════════════════════════════════════ -->
    <section id="find-us" class="relative scroll-mt-24 bg-void py-28 md:py-36">
      <div
        class="pointer-events-none absolute top-0 left-1/2 h-px w-4/5 max-w-4xl -translate-x-1/2 bg-gradient-to-r from-transparent via-amber/30 to-transparent"
        aria-hidden="true"
      >
      </div>

      <div class="mx-auto max-w-7xl px-6 md:px-10">
        <div class="reveal mb-20 max-w-2xl">
          <div class="mb-6 flex items-center gap-4">
            <span class="h-px w-12 bg-amber"></span>
            <span class="font-body text-xs font-medium uppercase tracking-[0.4em] text-amber"
              >Finndu okkur</span
            >
          </div>
          <h2
            class="font-display text-3xl font-semibold tracking-[0.12em] text-cream md:text-4xl lg:text-5xl"
          >
            Heimsókn og samband
          </h2>
          <p class="mt-6 font-body text-xl text-stone">
            Engar tímapantanir — bara mættu þegar við erum opin.
          </p>
        </div>

        <div class="grid gap-16 lg:grid-cols-2 lg:gap-24">
          <div class="reveal space-y-12">
            <div class="relative aspect-[4/3] overflow-hidden rounded-sm border border-border bg-surface">
              <Image
                src={storefront}
                alt="Húsnæði Shave Cave klippistofu við Fákafeni 9, 108 Reykjavík"
                width={1100}
                quality={80}
                format="webp"
                class="absolute inset-0 h-full w-full object-cover"
              />
              <div
                class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/50 to-transparent"
                aria-hidden="true"
              >
              </div>
            </div>

            <div>
              <h3 class="font-display text-sm tracking-[0.25em] text-amber">
                Staðsetning
              </h3>
              <p class="mt-4 font-body text-2xl text-cream">
                {business.street}<br />
                <span class="text-stone">{business.postalCode} {business.city}</span>
              </p>
            </div>

            <div>
              <h3 class="font-display text-sm tracking-[0.25em] text-amber">
                Sími og netfang
              </h3>
              <div class="mt-4 space-y-2">
                <p>
                  <a
                    href={`tel:${business.phoneHref}`}
                    class="font-body text-2xl text-cream transition-colors hover:text-amber-light"
                  >
                    {business.phoneDisplay}
                  </a>
                </p>
                <p>
                  <a
                    href={`mailto:${business.email}`}
                    class="font-body text-xl text-stone transition-colors hover:text-amber-light"
                  >
                    {business.email}
                  </a>
                </p>
              </div>
            </div>
          </div>

          <div class="reveal delay-2 flex flex-col gap-6">
            <!-- Static map (build-time OpenStreetMap render) — no third-party
                 request at runtime. Click opens directions in a new tab. -->
            <a
              href="https://www.google.com/maps/dir/?api=1&destination=F%C3%A1kafeni+9,+108+Reykjav%C3%ADk,+Iceland"
              target="_blank"
              rel="noopener noreferrer"
              data-directions
              class="group relative block aspect-[4/3] overflow-hidden rounded-sm border border-border bg-surface"
              aria-label="Opna leiðarlýsingu að Fákafeni 9 í Google Maps"
            >
              <img
                src="/map.webp"
                alt="Kort sem sýnir staðsetningu ShaveCave við Fákafeni 9, 108 Reykjavík"
                width="768"
                height="512"
                loading="lazy"
                decoding="async"
                class="absolute inset-0 h-full w-full object-cover opacity-90 transition-opacity duration-300 group-hover:opacity-100"
              />
              <div
                class="pointer-events-none absolute inset-0 border border-border bg-gradient-to-t from-void/40 to-transparent"
              >
              </div>
              <span
                class="pointer-events-none absolute bottom-1.5 right-2 font-body text-[0.6rem] leading-none text-cream/45"
                >© OpenStreetMap contributors</span
              >
