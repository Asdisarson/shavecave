  <!-- ═══════════════════════════════════════════════════════
       CLIENT-SIDE SCRIPTS
       ═══════════════════════════════════════════════════════ -->
  <script>
    function init() {
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      // ── Scroll reveals ────────────────────────────────
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
      );

      document
        .querySelectorAll(".reveal, .reveal-scale")
        .forEach((el) => observer.observe(el));

      // ── Hero character animation ──────────────────────
      const title = document.getElementById("hero-title");
      if (title && !reduceMotion) {
        const html = title.innerHTML;
        let charIndex = 0;
        const newHtml = html.replace(/(<[^>]+>)|(\S)/g, (_match, tag, char) => {
          if (tag) return tag;
          const delay = charIndex * 0.06;
          charIndex++;
          return `<span class="char" style="animation-delay:${delay}s">${char}</span>`;
        });
        title.innerHTML = newHtml;
      }

      // ── Nav scroll state ──────────────────────────────
      const nav = document.getElementById("nav");
      if (nav) {
        const onScroll = () => {
          nav.classList.toggle("nav-solid", window.scrollY > 60);
        };
        window.addEventListener("scroll", onScroll, { passive: true });
        onScroll();
      }

      // ── Mobile menu ───────────────────────────────────
      const toggle = document.getElementById("nav-toggle");
      const menu = document.getElementById("mobile-menu");
      if (toggle && menu) {
        let open = false;
        const setMenu = (state: boolean) => {
          open = state;
          menu.classList.toggle("translate-x-full", !open);
          menu.classList.toggle("translate-x-0", open);
          toggle.setAttribute("aria-expanded", String(open));
          toggle.setAttribute("aria-label", open ? "Loka valmynd" : "Opna valmynd");
          document.body.style.overflow = open ? "hidden" : "";

          const bars = toggle.querySelectorAll(".nav-bar");
          if (open) {
            bars[0]?.classList.add("translate-y-[6.5px]", "rotate-45");
            bars[1]?.classList.add("opacity-0");
            bars[2]?.classList.add("-translate-y-[6.5px]", "-rotate-45");
          } else {
            bars[0]?.classList.remove("translate-y-[6.5px]", "rotate-45");
            bars[1]?.classList.remove("opacity-0");
            bars[2]?.classList.remove("-translate-y-[6.5px]", "-rotate-45");
          }
        };
        toggle.addEventListener("click", () => setMenu(!open));
        menu.querySelectorAll("a").forEach((a) =>
          a.addEventListener("click", () => setMenu(false))
        );
        // If the viewport grows past the mobile breakpoint while the menu is
        // open, close it — otherwise the hamburger disappears and <body> stays
        // scroll-locked with no way to recover. (md = 768px)
        window
          .matchMedia("(min-width: 768px)")
          .addEventListener("change", (e) => {
            if (e.matches && open) setMenu(false);
          });
      }

      // ── Service card spotlight ────────────────────────
      document.querySelectorAll<HTMLElement>(".service-card").forEach((card) => {
        card.addEventListener("mousemove", (e) => {
          const rect = card.getBoundingClientRect();
          card.style.setProperty(
            "--mouse-x",
            `${e.clientX - rect.left}px`
          );
          card.style.setProperty(
            "--mouse-y",
            `${e.clientY - rect.top}px`
          );
        });
      });

      // ── Directions: start from the visitor's current location ─────────
      // The "Leiðarlýsing" links point at a Google Maps directions URL with
      // no origin, so Google guesses the start (on desktop ≈ the IP city —
      // "always the same spot"). If the browser can share the visitor's
      // location, inject it as the origin so the route starts where they
      // actually are. The directions tab opens immediately (never blank, never
      // popup-blocked) and is upgraded in place once geolocation resolves.
      // Modifier / non-primary clicks fall through to the native
      // rel="noopener" anchor (open-in-new-tab, etc.).
      document
        .querySelectorAll<HTMLAnchorElement>("a[data-directions]")
        .forEach((link) => {
          link.addEventListener("click", (e) => {
            if (
              !navigator.geolocation ||
              e.button !== 0 ||
              e.metaKey ||
              e.ctrlKey ||
              e.shiftKey ||
              e.altKey
            )
              return;
            e.preventDefault();
            const fallback = link.href;
            // Open the directions right away (no blank/hung tab) and sever the
            // opener back-reference — rel="noopener" on the anchor does not
            // carry to window.open(). Upgrade the URL in place once we have a
            // location; on denial/timeout the fallback is already showing.
            const tab = window.open("", "_blank");
            if (tab) {
              tab.opener = null;
              tab.location.href = fallback;
            }
            const go = (url: string) => {
              if (tab) tab.location.href = url;
              else window.location.href = url;
            };
            navigator.geolocation.getCurrentPosition(
              (pos) => {
                try {
                  const url = new URL(fallback);
                  url.searchParams.set(
                    "origin",
                    `${pos.coords.latitude},${pos.coords.longitude}`
                  );
                  go(url.href);
                } catch {
                  if (!tab) go(fallback);
                }
              },
              () => {
                if (!tab) go(fallback);
              },
              { enableHighAccuracy: false, timeout: 8000, maximumAge: 300000 }
            );
          });
        });

      // ── Open / Closed status ──────────────────────────
      // Open/close minutes come from the #status-badge data attributes, which
      // are derived from src/data/site.ts — kept in sync with the hours table.
      const statusBadge = document.getElementById("status-badge");
      const openMin = Number(statusBadge?.dataset.openMin ?? 555);
      const closeMin = Number(statusBadge?.dataset.closeMin ?? 1080);
      const updateStatus = () => {
        const now = new Date();
        const utc = now.getTime() + now.getTimezoneOffset() * 60000;
        const reykjavik = new Date(utc); // Iceland is UTC+0 year-round
        const day = reykjavik.getDay();
        const h = reykjavik.getHours();
        const m = reykjavik.getMinutes();
        const mins = h * 60 + m;
        const isWeekday = day >= 1 && day <= 5;
        const isOpen = isWeekday && mins >= openMin && mins < closeMin;

        const dots = document.querySelectorAll<HTMLElement>(".status-dot");
        const texts = [
          document.getElementById("status-text"),
          document.getElementById("mobile-status-text"),
        ];

        dots.forEach((dot) => {
          dot.classList.toggle("bg-green-500", isOpen);
          dot.classList.toggle("bg-stone-dark", !isOpen);
        });
        texts.forEach((el) => {
          if (el) {
            el.textContent = isOpen ? "Opið" : "Lokað";
            el.classList.toggle("text-green-500", isOpen);
            el.classList.toggle("text-stone-dark", !isOpen);
          }
        });
      };
      updateStatus();
      setInterval(updateStatus, 60_000);

      // ── Hero parallax on scroll ───────────────────────
      const hero = document.getElementById("hero");
      if (hero && !reduceMotion) {
        const heroContent = hero.querySelector(".relative.z-10") as HTMLElement | null;
        window.addEventListener(
          "scroll",
          () => {
            const scroll = window.scrollY;
            const vh = window.innerHeight;
            if (scroll < vh && heroContent) {
              const progress = scroll / vh;
              heroContent.style.opacity = `${1 - progress * 1.2}`;
              heroContent.style.transform = `translateY(${scroll * 0.3}px)`;
            }
          },
          { passive: true }
        );
      }
    }

    init();
  </script>
</Layout>
